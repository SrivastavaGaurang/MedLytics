rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Blogs ──────────────────────────────────────────────────────────────
    // Anyone can read published blogs
    // Only authenticated users can create
    // Only the author can update/delete their blog
    match /blogs/{blogId} {
      allow read: if resource.data.published == true;
      allow create: if request.auth != null
        && request.resource.data.authorId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.authorId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.authorId == request.auth.uid;
    }

    // ─── User Analysis Data ──────────────────────────────────────────────────
    // Only the authenticated owner can read/write their own analysis data
    match /users/{userId}/{collection}/{docId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // ─── Contact Submissions ─────────────────────────────────────────────────
    // Anyone can submit a contact form
    match /contacts/{contactId} {
      allow create: if true;
      allow read, update, delete: if false; // Admin-only (manage via Firebase Console)
    }
  }
}
