# Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# MongoDB Configuration
# Atlas (SRV — default in Atlas UI):
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/medlytics?retryWrites=true&w=majority
#
# If you see: querySrv ECONNREFUSED _mongodb._tcp...  → DNS/VPN/corporate network blocks SRV lookups.
# Fixes: use another network, turn off VPN, set Windows DNS to 8.8.8.8, or use Atlas "standard"
# connection string (mongodb://host1:27017,host2:27017/... not mongodb+srv), or use local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/medlytics
MONGO_URI=mongodb://127.0.0.1:27017/medlytics

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=24h

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:5000/api/oauth/google/callback
