# ─── Frontend Environment Variables (medlytics/.env) ─────────────────────────
# Copy to: medlytics/.env

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Express analysis server URL (still needed for analysis computation)
VITE_API_URL=http://localhost:5000/api
# Production example: https://medlytics-api.onrender.com/api

# ─── Backend Environment Variables (server/.env) ──────────────────────────────
# Copy to: server/.env

PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
# Production example: https://medlytics.vercel.app
